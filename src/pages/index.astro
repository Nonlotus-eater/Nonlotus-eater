---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import avatar from '@/assets/avatar_frz.jpg'
import config from '@/site-config'

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

// Statistics calculations
const totalPosts = allPosts.length
const lastUpdateDate = allPosts.length > 0
  ? (sortMDByDate(allPosts)[0].data.publishDate as Date)
  : null
const lastUpdateFormatted = lastUpdateDate
  ? lastUpdateDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : 'No posts yet'

// Calculate master's duration (from Sept 1, 2026)
const masterStartDate = new Date('2026-09-01')
const today = new Date()
const daysDiff = Math.floor((today.getTime() - masterStartDate.getTime()) / (1000 * 60 * 60 * 24))
const masterDuration = daysDiff >= 0
  ? `${daysDiff} days`
  : `${Math.abs(daysDiff)} days left`
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={avatar}
        alt='profile'
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-bold'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='China'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label
            title='My GitHub'
            as='a'
            href='https://github.com/Nonlotus-eater'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About Me'>
        <p class='text-muted-foreground'>Student</p>
        <p class='text-muted-foreground'>
          这里是Fridge,来自南京信息工程大学(2022级),正在努力学习CS&ai的相关知识,已推免至电子科技大学深圳高等研究院,
          正投入在时空智能、向量近似搜索领域的研究,后续会在博客中不断更新自己的学习笔记和学术成果. If interested,
          please feel free to contact me!
        </p>
        <Button title='More about me' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>

      <Section title='Education'>
        <div class="flex flex-col gap-3">
          <Card
            as='a'
            heading='Nanjing University of Information Science & Technology'
            subheading='Major: Data Science'
            date='September 2022 - Present'
            href='https://www.youtube.com/watch?v=dQw4w9WgXcQ'
          >
          </Card>
          <Card
            as='a'
            heading='University of Electronic Science and Technology'
            subheading='Major: Computer Science'
            date='September 2026'
          >
          </Card>
        </div>
      </Section>

      <Section title="Statistics">
        <div class="flex flex-col gap-4 sm:flex-row">
          <Card class="flex-1">
            <div class="flex flex-col items-center justify-center text-center">
              <Icon name="document" class="mb-2 size-8" />
              <p class="text-4xl font-bold">{totalPosts}</p>
              <p class="mt-2 text-muted-foreground">Total Posts</p>
            </div>
          </Card>
          <Card class="flex-1">
            <div class="flex flex-col items-center justify-center text-center">
              <Icon name="calendar" class="mb-2 size-8" />
              <p class="text-xl font-bold">{lastUpdateFormatted}</p>
              <p class="mt-2 text-muted-foreground">Last Updated</p>
            </div>
          </Card>
          <Card class="flex-1">
            <div class="flex flex-col items-center justify-center text-center">
              <svg class="mb-2 size-8" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg">
                <path fill="currentColor" d="M462.592 103.808c17.856-4.544 35.2-7.808 49.408-7.808 14.208 0 31.552 3.2 49.408 7.808 18.432 4.672 39.552 11.328 62.08 19.328 44.928 16 96.768 37.696 145.92 61.184 49.024 23.424 96.32 49.088 131.84 72.96 17.6 11.904 33.408 24.064 45.184 35.968 5.888 5.952 11.52 12.608 15.808 19.84 4.224 7.04 8.448 16.768 8.448 28.224 0 11.52-4.224 21.12-8.448 28.224a106.496 106.496 0 0 1-15.808 19.84 282.88 282.88 0 0 1-39.808 32.256v276.224c3.648 8.128 8.32 16.832 14.016 27.52 3.776 7.04 8 14.976 12.608 24.064 12.288 24.064 25.6 53.12 33.472 86.4 5.312 22.144 8.448 51.456-12.416 72.384a64.64 64.64 0 0 1-32.448 16.768 158.08 158.08 0 0 1-33.728 3.008h-26.88c-11.584 0-23.232-0.64-33.792-3.008a64.576 64.576 0 0 1-32.448-16.768c-20.864-20.928-17.728-50.24-12.416-72.384 7.872-33.28 21.12-62.336 33.472-86.4 4.608-9.088 8.832-17.024 12.608-24.064 5.76-10.688 10.368-19.392 13.952-27.52V460.8c-13.824 7.68-28.352 15.36-43.2 22.848l-9.92 227.264a89.216 89.216 0 0 1-3.52 22.144 99.2 99.2 0 0 1-36.352 52.608c-28.544 20.48-66.56 34.496-106.816 43.52a610.752 610.752 0 0 1-130.816 13.44c-44.864 0-90.112-4.416-130.88-13.44-40.32-9.024-78.208-23.04-106.752-43.52a99.2 99.2 0 0 1-36.416-52.608c-2.496-8.32-3.2-16.128-3.456-22.144l-9.92-227.328c-38.016-19.2-73.6-39.232-101.76-58.24a300.608 300.608 0 0 1-45.248-35.904 106.56 106.56 0 0 1-15.808-19.904 55.36 55.36 0 0 1-8.448-28.16c0-11.52 4.224-21.184 8.448-28.224 4.288-7.296 9.92-13.952 15.808-19.84 11.776-11.968 27.52-24.128 45.184-36.032 35.52-23.872 82.816-49.536 131.84-72.96a1559.68 1559.68 0 0 1 145.92-61.184c22.528-8 43.648-14.656 62.08-19.328z m-346.176 242.56l0.128-0.128-0.128 0.192z m3.84-5.056c0.768 0.96 1.728 1.984 2.88 3.2 7.488 7.552 19.328 16.96 35.392 27.776 31.872 21.44 76.096 45.568 123.648 68.288 47.36 22.72 97.152 43.52 139.776 58.624 21.312 7.552 40.448 13.568 56.384 17.664 16.576 4.16 27.648 5.76 33.664 5.76 6.016 0 17.088-1.6 33.664-5.76 15.936-4.096 35.072-10.112 56.384-17.664a1496.64 